{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/pickup-calendar.ics",
      "destination": "/api/pickup-calendar"
    },
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/order-collector",
      "destination": "/order-collector.html"
    },
    {
      "source": "/tv/pickup",
      "destination": "/tv-pickup.html"
    }
  ],
  "functions": {
    "api/sync-orders.js": {
      "regions": ["icn1"],
      "maxDuration": 300
    },
    "api/order-collector.js": {
      "regions": ["icn1"],
      "maxDuration": 300
    },
    "api/sync-ops-data.js": {
      "regions": ["icn1"],
      "maxDuration": 300
    },
    "api/search-orders.js": {
      "regions": ["icn1"]
    },
    "api/admin-dashboard-data.js": {
      "regions": ["icn1"]
    },
    "api/admin-dashboard-customers.js": {
      "regions": ["icn1"]
    },
    "api/admin-dashboard-kakao-user.js": {
      "regions": ["icn1"]
    },
    "api/tv-pickup.js": {
      "regions": ["icn1"]
    }
  },
  "crons": [
    {
      "path": "/api/sync-orders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/sync-ops-data",
      "schedule": "*/15 * * * *"
    }
  ]
}
