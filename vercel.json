{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/pickup-calendar.ics",
      "destination": "/api/pickup-calendar"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/sync-orders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/sync-pickup-completions",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/sync-ops-data",
      "schedule": "*/15 * * * *"
    }
  ]
}
